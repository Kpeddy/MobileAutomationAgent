# BrowserStack Credentials
BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key

# App URL (obtained after uploading APK/IPA to BrowserStack)
BROWSERSTACK_APP_URL=bs://your_app_hash_here

# Set to "true" to run against local Appium instead of BrowserStack
USE_LOCAL=false

# Local Appium config (only used if USE_LOCAL=true)
APPIUM_HOST=localhost
APPIUM_PORT=4723
